# ---------------------------------------------------------------------------
# OSARE — East Africa Safari Routes & Transit Hub — Environment variables
# Copy to .env (local) or set these in Render / your host (production)
# ---------------------------------------------------------------------------

# PostgreSQL connection string (NEON). Get it from your NEON project ->
# "Connection Details". Example:
# postgresql://<user>:<password>@ep-xxxx-pooler.<region>.aws.neon.tech/<dbname>?sslmode=require
# NOTE: the app automatically strips '&channel_binding=require' because the
# Node 'pg' driver does not support SCRAM channel binding.
DATABASE_URL=postgresql://user:password@host.neon.tech/dbname?sslmode=require

# Public base URL of the deployed app
# Example: https://easafariroutes.com  or  https://osare.onrender.com
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Allowed CORS origins ('*' for open)
CORS_ORIGINS=*
